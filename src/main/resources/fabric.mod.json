{
  "schemaVersion": 1,
  "id": "malioptrender",
  "version": "${version}",
  "name": "MaliOpt Renderer",
  "description": "Otimização visual e pipeline TBDR para GPUs ARM Mali",
  "authors": ["Denotas"],
  "contact": {
    "homepage": "https://github.com/denotas235/maliopt-renderer",
    "sources": "https://github.com/denotas235/maliopt-renderer"
  },
  "license": "Apache-2.0",
  "icon": "assets/malioptrender/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["com.maliopt.MaliOptMod"],
    "modmenu": ["com.maliopt.MaliOptMod"]
  },
  "mixins": [
    "maliopt.mixins.json",
    "maliopt.texture.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*",
    "yet_another_config_lib_v3": "*",
    "modmenu": "*"
  },
  "suggests": {
    "sodium": "*",
    "iris": "*"
  }
}
